rules_version = '2';

// Security rules for CarpenterHub.
//
// Admin status is a Firestore-collection allowlist (`admins/{uid}`),
// checked via exists() below, rather than a custom auth claim -- custom
// claims need a Cloud Function or the Admin SDK to set, both of which
// require the paid Blaze plan; this project intentionally stays on Spark
// (see the Cloudinary-instead-of-Storage note elsewhere in the repo).
// Admin accounts are provisioned by hand: create the Firebase Auth user
// in the Console, then add a doc at `admins/{that user's uid}` (content
// doesn't matter, only existence does). Never done through either app.
//
// Previously isAdmin() was just isSignedIn() -- meaning any authenticated
// user, including a carpenter who just self-registered in the mobile app,
// had admin-level write access to every collection below. Combined with
// admin_console's login screen auto-creating an account for whatever
// email/password was typed in, this meant anyone who found the public
// admin URL could grant themselves full write access with one login
// attempt. Both halves of that are now fixed (this file, and
// admin_console's login flow no longer auto-creates accounts).

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(carpenterId) {
      return isSignedIn() && request.auth.uid == carpenterId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // The order-creator role: can log party orders (below) but nothing else.
    function isOrderCreator() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/orderCreators/$(request.auth.uid));
    }

    // A user may check ONLY their own admin status (needed for the
    // client-side gate in admin_console) -- never list or read anyone
    // else's, and never write: admin status changes only via the
    // Console/Admin SDK, which bypass rules entirely.
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // Same self-read-only allowlist for the order-creator role.
    match /orderCreators/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // Party orders: logged by an order-creator, reviewed/paid by an admin.
    // The carpenter app never touches this collection -- only the points
    // from each payment reach the carpenter (via pointsLedger, written by
    // the admin's transaction below, which isAdmin already gates).
    //   - order-creator: create their own; update ONLY while still pending
    //     (so an admin's approval/payments can't be edited out from under
    //     them), and only their own docs.
    //   - admin: full read/write (approve, record payments, complete).
    match /partyOrders/{orderId} {
      allow read: if isAdmin() ||
        (isOrderCreator() && resource.data.createdBy == request.auth.uid);
      allow create: if isOrderCreator() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isAdmin() ||
        (isOrderCreator() &&
         resource.data.createdBy == request.auth.uid &&
         resource.data.status == 'pending' &&
         // A creator edit must stay a pending order it still owns -- it
         // can't flip status to 'approved' or reassign createdBy.
         request.resource.data.status == 'pending' &&
         request.resource.data.createdBy == resource.data.createdBy);
      allow delete: if isAdmin();
    }

    match /carpenters/{carpenterId} {
      allow read: if isSignedIn();
      allow create: if isOwner(carpenterId);
      allow update: if isOwner(carpenterId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.carpenterId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /offers/{offerId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /gifts/{giftId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /giftRedemptions/{redemptionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.carpenterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /leads/{leadId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.carpenterId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /pointsLedger/{entryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Admin broadcast log (persisted notification-send history).
    match /broadcasts/{broadcastId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Admin-editable points/redeem rules, shared by both apps.
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Atomic order-number counter. Carpenters bump this in a transaction
    // when creating an order, so it needs to be writable by any signed-in
    // user, not just admins.
    match /counters/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
